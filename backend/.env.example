# Database configuration (Supabase connection)
# Make sure to use the postgresql+asyncpg driver for SQLAlchemy async support
DATABASE_URL=postgresql+asyncpg://postgres:your_password@db.your_project.supabase.co:5432/postgres
SUPABASE_URL=https://your_project.supabase.co
SUPABASE_KEY=your_supabase_publishable_or_service_key

# OpenAI API credentials (commented out — using Ollama instead)
# OPENAI_API_KEY=your_openai_api_key_here
# EMBEDDING_MODEL=text-embedding-3-small
# LLM_MODEL=gpt-4o

# Ollama configurations (local LLM)
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=qwen3.5:latest
EMBEDDING_MODEL=qwen3.5:latest

# RAG Threshold (below which internet search is triggered)
RAG_CONFIDENCE_THRESHOLD=0.7

# Search service configuration (Optional: Tavily or Google Search API. Fallbacks to DuckDuckGo if empty)
TAVILY_API_KEY=

# Security settings
SECRET_KEY=your_super_secret_jwt_key_here
ACCESS_TOKEN_EXPIRE_MINUTES=1440
RATE_LIMIT_PER_MINUTE=60
